# ─────────────────────────────────────────────────────
# Copy this file to .env.local for local development
# In Vercel: Settings → Environment Variables
# ─────────────────────────────────────────────────────

# Your Render backend URL (NO trailing slash)
# Example: https://qti-backend.onrender.com
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND-NAME.onrender.com

# ─── HOW TO FIND YOUR RENDER URL ──────────────────────
# 1. Go to render.com → Dashboard → your service
# 2. Copy the URL shown at the top (looks like https://xxx.onrender.com)
# 3. Paste it above, replacing YOUR-BACKEND-NAME
# ──────────────────────────────────────────────────────
